# ============================================================
# VOCA — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file lives in the root of the project (never commit it).
# ============================================================

# ── DATABASE (CockroachDB) ───────────────────────────────────
# 1. Go to https://cockroachlabs.cloud → Create free cluster
# 2. Click "Connect" → choose "Connection string"
# 3. Copy the postgres:// URL and paste below
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:26257/voca?sslmode=verify-full"

# ── AUTH (NextAuth.js) ────────────────────────────────────────
# Generate a secret: run → openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Your deployed frontend URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"

# ── CLOUDFLARE R2 (File Storage) ─────────────────────────────
# 1. Go to https://dash.cloudflare.com → R2 Object Storage
# 2. Create a bucket named "voca-storage"
# 3. Go to "Manage R2 API Tokens" → Create token with Read+Write
# 4. In bucket settings → enable "Public access" for streaming
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="voca-storage"
# Public URL for your R2 bucket (e.g. https://pub-xxx.r2.dev or custom domain)
R2_PUBLIC_URL="https://pub-XXXXXXXX.r2.dev"

# ── HF SPACES BACKEND (optional fallback TTS) ─────────────────
# Your Hugging Face Space URL after deploying backend/
# Leave empty to use browser-only TTS
HF_TTS_URL="https://YOUR-USERNAME-voca-tts.hf.space"

# ── MOBILE (Capacitor) ────────────────────────────────────────
# Empty on web (same-origin fetches). Set to the deployed Vercel URL
# for mobile builds so the APK's WebView can reach /api/* cross-origin.
# Only read when MOBILE_BUILD=1 during `npm run build`.
NEXT_PUBLIC_API_BASE_URL=""
