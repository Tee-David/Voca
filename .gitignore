# ─── Dependencies ────────────────────────────────────────────
node_modules/
.pnp
.pnp.*

# ─── Next.js build output ────────────────────────────────────
frontend/.next/
frontend/out/
frontend/.vercel/
frontend/.turbo/

# ─── Python (backend) ────────────────────────────────────────
backend/__pycache__/
backend/*.pyc
backend/.venv/
backend/venv/

# ─── Build artifacts ─────────────────────────────────────────
build/
dist/
coverage/

# ─── Secrets & environment ───────────────────────────────────
