.env
.env.local
.env.*.local
.env.production
.env.development
env/

# ─── Certificates & keys ─────────────────────────────────────
*.pem
*.key
*.crt
*.cert
*.pfx
*.p12

# ─── Editor / IDE / agent config ─────────────────────────────
.vscode/
.idea/
.claude/
.aider*
.cursor/
*.swp
*.swo

# ─── OS noise ────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Prisma generated client (per-env) ───────────────────────
frontend/src/generated/prisma/
