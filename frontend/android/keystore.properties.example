# Copy this to frontend/android/keystore.properties (which is gitignored) and fill in.
# Generate the keystore with:
#   keytool -genkey -keystore voca-release.jks -alias voca -keyalg RSA -keysize 2048 -validity 10000
# Then back up voca-release.jks to a password manager / encrypted vault.
# Losing it = you can never sign a Play Store update for this app ID again.

storeFile=voca-release.jks
storePassword=REPLACE_ME
keyAlias=voca
keyPassword=REPLACE_ME
