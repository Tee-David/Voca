{
  "name": "voca",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next dev",
    "build": "cross-env SERWIST_SUPPRESS_TURBOPACK_WARNING=1 prisma generate && cross-env SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "mobile:build": "cross-env MOBILE_BUILD=1 NEXT_PUBLIC_API_BASE_URL=https://voca-cyan.vercel.app SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next build",
    "mobile:sync": "npm run mobile:build && cap sync android",
    "mobile:open": "cap open android",
    "mobile:apk": "npm run mobile:sync && cd android && ./gradlew assembleRelease",
    "mobile:apk:debug": "npm run mobile:sync && cd android && ./gradlew assembleDebug",
    "mobile:assets": "capacitor-assets generate --android",
    "mobile:release": "npm run mobile:build && cap sync android && npx @capgo/cli bundle upload"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@base-ui/react": "^1.4.0",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.0.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@capgo/capacitor-updater": "^8.45.0",
    "capacitor-blob-writer": "^1.1.20",
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^5.22.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@serwist/next": "^9.5.7",
    "@tanstack/react-query": "^5.99.0",
    "bcryptjs": "^3.0.3",
    "boneyard-js": "^1.7.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "epubjs": "^0.3.93",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "howler": "^2.2.4",
    "idb": "^8.0.3",
    "jsdom": "^29.0.2",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serwist": "^9.5.7",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^5.1.1",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/howler": "^2.2.12",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@capacitor/assets": "^3.0.5"
  }
}
